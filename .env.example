# 환경변수 견본 파일
# .env 파일에 아래 값을 채워 넣으세요.
POSTGRES_DB=teamg_db
POSTGRES_USER=techeer_teamg
POSTGRES_PASSWORD=(팀원 이름 가나다순으로 영문 소문자 이니셜, 민재헌에게 문의)
ANTHROPIC_API_KEY=(민재헌에게 문의)
GOOGLE_MAPS_API_KEY=(민재헌에게 문의)
SERPAPI_KEY=(민재헌에게 문의)
LITEAPI_KEY=(민재헌에게 문의)
DJANGO_SECRET_KEY=(민재헌에게 문의)

# 주의: 키 이름은 DJANGO_DEBUG (예전 견본의 DJANGO_BUG는 오타 — settings가 못 읽어서
# 기본값 true로 떴음). 운영에서는 반드시 false!
DJANGO_DEBUG=false

# 허용 호스트 (쉼표 구분, 공백 없이)
#  - 로컬 개발: localhost,127.0.0.1
#  - 운영: 도메인,EC2 IP,web
#    ("web"은 도커 내부에서 Prometheus가 지표를 긁는 주소 — 빼면 모니터링 수집 실패)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

POSTGRES_HOST=(RDS 엔드포인트. 민재헌에게 문의)
CORS_ALLOWED_ORIGINS=(Vercel 프론트 도메인, 예: https://xxx.vercel.app)
TOSS_CLIENT_KEY=(토스 개발자센터 테스트 키 test_ck_... — 프론트 노출용)
TOSS_SECRET_KEY=(토스 개발자센터 테스트 키 test_sk_... — 백엔드 전용, 절대 노출 금지)

# Grafana 관리자 비밀번호 (모니터링 스택 — docker-compose.monitoring.yml이 읽음)
# 첫 기동 때만 적용되고, 이후 변경은 Grafana 웹 UI에서
GRAFANA_ADMIN_PASSWORD=(원하는 값으로 설정)
